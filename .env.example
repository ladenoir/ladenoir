NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-key

# Cloudflare R2 (product image storage) — enable R2 in the Cloudflare dashboard,
# create a bucket, then mint an R2 S3 API token for these values.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=la-de-noir-media
R2_PUBLIC_BASE=https://your-bucket-public-url.r2.dev
